<Window x:Class="CryptoSelfBot.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CryptoSelfBot.Wpf.ViewModels"
        xmlns:hdr="clr-namespace:CryptoSelfBot.Wpf.Components.Header"
        xmlns:menu="clr-namespace:CryptoSelfBot.Wpf.Components.Menu"
        xmlns:localCards="clr-namespace:CryptoSelfBot.Wpf.Components.Cards"
        xmlns:components="clr-namespace:CryptoSelfBot.Wpf.Components.Menu"
        xmlns:controls="clr-namespace:CryptoSelfBot.Wpf.Controls"
        Title="CryptoSelfBot"
        Height="950"
        Width="1600"
        MinWidth="1400"
        MinHeight="900"
        ResizeMode="CanResize"
        AllowsTransparency="False"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="120"/>
            <RowDefinition Height="260"/>
            <RowDefinition Height="100"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="180"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!-- HEADER: reutilizar UserControl HeaderControl -->
        <hdr:HeaderControl x:Name="HeaderControl" Grid.Row="0"/>

        <!-- MARKET -->
        <Grid Grid.Row="1" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- CRYPTO -->
            <Border Grid.Column="0" CornerRadius="24"
                    Background="{DynamicResource CardBackgroundBrush}" Padding="24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="WATCHLIST CRYPTO" FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Width="40" Height="40"
                                Content="+" FontSize="18" FontWeight="Bold"
                                Background="{DynamicResource PrimaryBrush}" Foreground="{DynamicResource TextBrush}"
                                BorderThickness="0" Cursor="Hand" Click="AddCrypto_Click"/>
                        <controls:IconButton Grid.Column="2" Width="40" Height="40" Margin="10,0,0,0">
                            <Button Background="{DynamicResource PrimaryBrush}" BorderThickness="0" Click="ForceRefreshPrices_Click" Width="40" Height="40">
                                <Viewbox Width="18" Height="18">
                                    <Path Fill="White" Data="M12 2V6L16 2L20 6V2H12ZM4 8V22H20V8H4Z"/>
                                </Viewbox>
                            </Button>
                        </controls:IconButton>
                    </Grid>
                    <ListBox x:Name="CryptoListBox" Grid.Row="1" Margin="0,20,0,0" Background="Transparent" BorderThickness="0"
                             ItemsSource="{Binding CryptoAssets}">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,10"/>
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <localCards:CryptoCard/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- FIAT -->
            <Border Grid.Column="2" CornerRadius="24"
                    Background="{DynamicResource CardBackgroundBrush}" Padding="24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="FIAT MARKET" FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Width="40" Height="40"
                                Content="+" FontSize="18" FontWeight="Bold"
                                Background="{DynamicResource PrimaryBrush}" Foreground="{DynamicResource TextBrush}"
                                BorderThickness="0" Cursor="Hand" Click="AddFiat_Click"/>
                    </Grid>
                    <ListBox Grid.Row="1" Margin="0,20,0,0" Background="Transparent" BorderThickness="0"
                             ItemsSource="{Binding FiatAssets}">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,10"/>
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource CardBrush}" CornerRadius="14" Padding="14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Symbol}" FontSize="18" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Value}" HorizontalAlignment="Right"
                                                   Foreground="{DynamicResource SuccessBrush}" FontWeight="Bold" FontSize="18"
                                                   VerticalAlignment="Center"/>
                                        <controls:IconButton Grid.Column="2" Width="34" Height="34">
                                            <Button Width="34" Height="34" Background="{DynamicResource DangerBrush}" BorderThickness="0" Click="RemoveFiat_Click" Tag="{Binding}">
                                                <Viewbox Width="14" Height="14">
                                                    <Path Fill="White" Data="M6 2L2 6M2 2L6 6"/>
                                                </Viewbox>
                                            </Button>
                                        </controls:IconButton>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <!-- START/STOP BUTTONS -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <controls:ModernButton Width="120" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,10,0">
                <Button Content="Iniciar" Style="{StaticResource PrimaryButton}" Click="StartButton_Click"/>
            </controls:ModernButton>
            <controls:ModernButton Width="120" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button Content="Detener" Style="{StaticResource SecondaryButton}" Click="StopButton_Click"/>
            </controls:ModernButton>
        </StackPanel>

        <!-- MENU: reutilizar MenuControl -->
        <components:MenuControl Grid.Row="3" x:Name="AppMenu" />

        <!-- CONSOLA DE PROCESOS (scroll corregido) -->
        <Border Grid.Row="4" Margin="0,0,0,10" CornerRadius="16"
                Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrushColor}" BorderThickness="1" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="CONSOLA DE PROCESOS" FontSize="14" FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,5"/>
                <ListBox x:Name="ConsoleLogListBox" Grid.Row="1" 
                         FontFamily="Consolas" FontSize="12"
                         Background="Transparent" Foreground="{DynamicResource PrimaryBrush}"
                         BorderThickness="0" IsTabStop="False"
                         VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         SelectionMode="Extended"
                         ItemsSource="{Binding LogsList}"/>
            </Grid>
        </Border>

        <!-- FOOTER -->
        <Border Grid.Row="5" CornerRadius="16"
                Background="{DynamicResource CardBackgroundBrush}" Padding="12,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="160"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextBrush}" FontSize="16" TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding StatusMessage}"/>
                <TextBlock Grid.Column="1" Text="{Binding ConnectionStatus}"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Foreground="{DynamicResource SuccessBrush}" FontWeight="Bold" FontSize="16"/>
            </Grid>
        </Border>
    </Grid>
</Window>