<Window x:Class="CryptoSelfBot.Wpf.Views.SourcesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Estado de Fuentes"
        Height="700"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="25">
        <Border Style="{DynamicResource DashboardCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="ESTADO DE FUENTES" Style="{DynamicResource TitleText}" Margin="0,0,0,20"/>

                <DataGrid Grid.Row="1" x:Name="SourcesDataGrid" Background="{DynamicResource CardBrush}" Foreground="{DynamicResource TextBrush}"
                          BorderThickness="0" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Fuente" Binding="{Binding Name}" Width="200"/>
                        <DataGridTemplateColumn Header="Estado" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="12" Height="12" Fill="{Binding StatusColor}" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusColor}"
                                                   ToolTip="{Binding TooltipText}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Último Error" Binding="{Binding LastError}" Width="250">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="ToolTip" Value="{Binding LastError}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Reintento" Binding="{Binding NextRetryUtc, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}" Width="150"/>
                        <DataGridTextColumn Header="Fallos consecutivos" Binding="{Binding ConsecutiveFailures}" Width="120"/>
                        <DataGridTextColumn Header="Uptime 24h" Binding="{Binding Uptime}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                    <Button Content="Exportar reporte" Width="150" Height="35" Margin="0,0,10,0"
                            Background="{DynamicResource PrimaryBrush}" Foreground="White" FontWeight="Bold" Click="ExportReport_Click"/>
                    <Button Content="Cerrar" Width="80" Height="35" Background="{DynamicResource DangerBrush}" Foreground="White"
                            FontWeight="Bold" IsCancel="True"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>