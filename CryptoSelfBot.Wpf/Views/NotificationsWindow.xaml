<Window x:Class="CryptoSelfBot.Wpf.Views.NotificationsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Notificaciones"
        Height="700"
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="25">

        <Border Style="{DynamicResource DashboardCard}">

            <StackPanel>

                <TextBlock Text="CENTRO DE NOTIFICACIONES"
                           Style="{DynamicResource TitleText}"/>

                <TextBlock Text="Los avisos aparecen aquí cuando la app registra conexiones, errores, noticias, señales u operaciones."
                           Foreground="{DynamicResource MutedTextBrush}"
                           Margin="0,12,0,0"
                           TextWrapping="Wrap"/>

                <ListBox Margin="0,20,0,0"
                         Height="520"
                         Background="{DynamicResource CardBrush}"
                         Foreground="{DynamicResource TextBrush}"
                         BorderThickness="0"
                         ItemsSource="{Binding Notifications}"/>

            </StackPanel>

        </Border>

    </Grid>

</Window>
