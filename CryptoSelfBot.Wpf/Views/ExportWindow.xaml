<Window x:Class="CryptoSelfBot.Wpf.Views.ExportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Exportar"
        Height="500"
        Width="800"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="25">

        <Border Style="{DynamicResource DashboardCard}">

            <StackPanel>

                <TextBlock Text="EXPORTAR DATOS"
                           Style="{DynamicResource TitleText}"/>

                <ComboBox Height="45"
                          Margin="0,30,0,0">

                    <ComboBoxItem Content="2026"/>
                    <ComboBoxItem Content="2025"/>
                    <ComboBoxItem Content="2024"/>

                </ComboBox>

                <Button Content="Exportar Excel"
                        Style="{DynamicResource PrimaryButton}"
                        Margin="0,30,0,0"/>

            </StackPanel>

        </Border>

    </Grid>

</Window>