<Window x:Class="CryptoSelfBot.Wpf.Views.CreditsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Créditos"
        Height="850"
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="40">

            <StackPanel>

                <!-- TITULO -->

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,30">
                    <Viewbox Width="48" Height="48" Margin="0,0,12,0">
                        <Rectangle Width="48" Height="48" Fill="{DynamicResource AppLogoBrush}"/>
                    </Viewbox>
                    <TextBlock Text="CRYPTOSELFBOT"
                               FontSize="46"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextBrush}"/>
                </StackPanel>

                <!-- AUTOR -->

                <Border Background="{DynamicResource CardBrush}"
                        CornerRadius="24"
                        Padding="30"
                        Margin="0,0,0,25">

                    <StackPanel>

                        <TextBlock Text="CREADOR"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryBrush}"/>

                        <TextBlock Text="Ernesto Pernett Cuesta"
                                   Margin="0,14,0,0"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}"/>

                        <TextBlock Text="Ingeniero Mecánico"
                                   Margin="0,6,0,0"
                                   FontSize="22"
                                   Foreground="{DynamicResource MutedTextBrush}"/>

                    </StackPanel>

                </Border>

                <!-- IA -->

                <Border Background="{DynamicResource CardBrush}"
                        CornerRadius="24"
                        Padding="30"
                        Margin="0,0,0,25">

                    <StackPanel>

                        <TextBlock Text="ARQUITECTURA IA"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryBrush}"/>

                        <StackPanel Margin="0,20,0,0">

                            <TextBlock Text="OpenAI ChatGPT"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Foreground="White"/>

                            <TextBlock Text="DeepSeek"
                                       Margin="0,12,0,0"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Foreground="White"/>

                            <TextBlock Text="Google Gemini"
                                       Margin="0,12,0,0"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Foreground="White"/>

                        </StackPanel>

                    </StackPanel>

                </Border>

                <!-- VERSION -->

                <Border Background="{DynamicResource CardBrush}"
                        CornerRadius="24"
                        Padding="30">

                    <StackPanel>

                        <TextBlock Text="VERSIÓN"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryBrush}"/>

                        <TextBlock Text="CryptoSelfBot v2.0"
                                   Margin="0,14,0,0"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}"/>

                        <TextBlock Text="Desarrollado con la asistencia de GitHub Copilot"
                                   Margin="0,14,0,0"
                                   FontSize="14"
                                   Foreground="{DynamicResource MutedTextBrush}"/>

                    </StackPanel>

                </Border>

            </StackPanel>

</Grid>
</Window>