<Window x:Class="CryptoSelfBot.Wpf.Views.NewsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Noticias"
        Height="700"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">
    <!-- All colors use DynamicResource for theming -->
    <Grid Margin="25">
        <Border Style="{DynamicResource DashboardCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="HISTORIAL DE NOTICIAS" Style="{DynamicResource TitleText}"/>
                    <TextBlock x:Name="SentimentSummaryText" Foreground="{DynamicResource MutedTextBrush}" FontSize="14" Margin="0,5,0,0"/>
                </StackPanel>

                <DataGrid Grid.Row="1" x:Name="NewsDataGrid" Background="{DynamicResource CardBrush}" Foreground="{DynamicResource TextBrush}"
                          BorderThickness="0" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Fecha" Binding="{Binding TimestampUtc, StringFormat='{}{0:dd/MM/yyyy HH:mm:ss}'}" Width="180"/>
                        <DataGridTextColumn Header="Par" Binding="{Binding Symbol}" Width="120"/>
                        <DataGridTextColumn Header="Tipo" Binding="{Binding Side}" Width="100"/>
                        <DataGridTextColumn Header="Score" Binding="{Binding Price, StringFormat='N4'}" Width="100"/>
                        <DataGridTextColumn Header="Notas" Binding="{Binding Notes}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                    <Button Content="Exportar noticias" Width="150" Height="35" Margin="0,0,10,0"
                            Background="{DynamicResource PrimaryBrush}" Foreground="{DynamicResource TextBrush}" FontWeight="Bold" Click="ExportNews_Click"/>
                    <Button Content="Cerrar" Width="80" Height="35" Background="{DynamicResource DangerBrush}" Foreground="{DynamicResource TextBrush}"
                            FontWeight="Bold" IsCancel="True"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>