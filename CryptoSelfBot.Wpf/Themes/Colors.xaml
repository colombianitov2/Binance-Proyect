<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- BASE -->

    <SolidColorBrush x:Key="WindowBackgroundBrush"
                     Color="#050B1A"/>

    <SolidColorBrush x:Key="CardBackgroundBrush"
                     Color="#0C152B"/>

    <SolidColorBrush x:Key="BorderBrushColor"
                     Color="#1C2742"/>

    <!-- COOLORS PALETTE -->

    <SolidColorBrush x:Key="JetBlackBrush"
                     Color="#2A2D34"/>

    <SolidColorBrush x:Key="BlueBellBrush"
                     Color="#009DDC"/>

    <SolidColorBrush x:Key="TigerFlameBrush"
                     Color="#F26430"/>

    <SolidColorBrush x:Key="DustyGrapeBrush"
                     Color="#6761A8"/>

    <SolidColorBrush x:Key="ShamrockBrush"
                     Color="#009B72"/>

    <!-- ALIAS Y RECURSOS CENTRALES -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#009DDC" />
    <SolidColorBrush x:Key="CardBrush" Color="#0C152B" />
    <SolidColorBrush x:Key="TextBrush" Color="#F2F2F2" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#94A3B8" />
    <SolidColorBrush x:Key="AccentBrush" Color="#F26430" />
    <SolidColorBrush x:Key="SectionHeaderBrush" Color="#E6EEF8" />
    <SolidColorBrush x:Key="SuccessBrush" Color="#16A34A" />
    <SolidColorBrush x:Key="DangerBrush" Color="#D7263D" />
    <SolidColorBrush x:Key="BackgroundBrush" Color="#050B1A" />

</ResourceDictionary>