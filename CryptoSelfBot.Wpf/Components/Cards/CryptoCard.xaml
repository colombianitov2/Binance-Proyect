<UserControl x:Class="CryptoSelfBot.Wpf.Components.Cards.CryptoCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             Height="52"
             Width="Auto">

    <Border
        Background="{DynamicResource CardBrush}"
        CornerRadius="12"
        Margin="0,0,0,10"
        Padding="16,10">

        <Grid>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="50" />
            </Grid.ColumnDefinitions>

            <!-- SYMBOL -->

            <TextBlock
                Text="{Binding Symbol}"
                FontSize="18"
                FontWeight="SemiBold"
                Foreground="{DynamicResource TextBrush}"
                VerticalAlignment="Center" />

            <!-- PRICE -->

            <TextBlock
                Grid.Column="1"
                Text="{Binding Price}"
                FontSize="17"
                Foreground="{DynamicResource TextBrush}"
                HorizontalAlignment="Right"
                VerticalAlignment="Center" />

            <!-- CHANGE -->

            <TextBlock
                Grid.Column="2"
                Text="{Binding Change}"
                FontSize="17"
                FontWeight="Bold"
                HorizontalAlignment="Right"
                VerticalAlignment="Center">

                <TextBlock.Style>
                    <Style TargetType="TextBlock">

                        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>

                        <Style.Triggers>

                            <DataTrigger
                                Binding="{Binding IsNegative}"
                                Value="True">

                                <Setter Property="Foreground"
                                        Value="{DynamicResource DangerBrush}"/>

                            </DataTrigger>

                        </Style.Triggers>

                    </Style>

                </TextBlock.Style>

            </TextBlock>

            <Button Grid.Column="3" Width="34" Height="34" FontSize="14"
                    FontWeight="Bold" Background="{DynamicResource DangerBrush}" Foreground="{DynamicResource TextBrush}"
                    BorderThickness="0" Cursor="Hand" Click="OnRemoveClicked" Tag="{Binding}">
                <iconPacks:PackIconMaterial Kind="Close" Width="14" Height="14" Foreground="{DynamicResource TextBrush}"/>
            </Button>

        </Grid>

    </Border>

</UserControl>