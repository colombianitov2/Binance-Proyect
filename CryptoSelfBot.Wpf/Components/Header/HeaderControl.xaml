<UserControl x:Class="CryptoSelfBot.Wpf.Components.Header.HeaderControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             Height="120" Width="Auto">
    <Border CornerRadius="24"
            Background="{DynamicResource CardBrush}"
            BorderBrush="{DynamicResource BorderBrushColor}"
            BorderThickness="1" Padding="20">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330"/>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="460"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal">
                <Border Width="64" Height="64" CornerRadius="18"
                        BorderBrush="{DynamicResource BorderBrushColor}" BorderThickness="2" ClipToBounds="True">
                    <TextBlock Text="CSB" FontSize="28" FontWeight="Bold"
                               Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="CryptoSelfBot" FontSize="34" FontWeight="Bold" Foreground="{DynamicResource TextBrush}"/>
                    <TextBlock Text="Sistema Autónomo Financiero" FontSize="16" Foreground="{DynamicResource MutedTextBrush}"/>
                </StackPanel>
            </StackPanel>

            <Border Grid.Column="1" Margin="20,0,10,0"
                    Background="{DynamicResource CardBrush}" CornerRadius="18" Padding="18">
                <StackPanel>
                    <TextBlock Text="BINANCE" Foreground="{DynamicResource MutedTextBrush}" FontSize="12" Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding ConnectionStatus}"
                               Foreground="{DynamicResource SuccessBrush}" FontWeight="Bold"
                               FontSize="18" TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Margin="10,0,20,0"
                    Background="{DynamicResource CardBrush}" CornerRadius="18" Padding="18">
                <StackPanel>
                    <TextBlock Text="ENGINE STATUS" Foreground="{DynamicResource MutedTextBrush}" FontSize="12" Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{DynamicResource TextBrush}" FontWeight="Bold"
                               FontSize="15" TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="500"/>
                </StackPanel>
            </Border>

            <TextBlock Grid.Column="4" HorizontalAlignment="Right" VerticalAlignment="Center"
                       FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextBrush}"
                       Text="{Binding CurrentDate}"/>

            <Border Grid.Column="5" Width="54" Height="54" CornerRadius="27"
                    BorderBrush="{DynamicResource BorderBrushColor}" BorderThickness="1"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Cursor="Hand">
                <Grid>
                    <Button x:Name="NotificationsButton" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextBrush}"
                            Click="NotificationToggle_Click">
                        <iconPacks:PackIconMaterial Kind="BellOutline" Width="24" Height="24" Foreground="{DynamicResource TextBrush}"/>
                    </Button>
                    <Border Width="24" Height="24" CornerRadius="12" Background="{DynamicResource DangerBrush}"
                            HorizontalAlignment="Right" VerticalAlignment="Top">
                        <TextBlock Text="{Binding Notifications.Count}" Foreground="{DynamicResource TextBrush}" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
